{
  "name": "fastmail-mcp",
  "version": "1.0.0",
  "description": "MCP server for Fastmail API integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "fastmail-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "tsx --test src/**/*.test.ts",
    "test:coverage": "c8 tsx --test src/**/*.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "ci": "npm run check && npm run test:coverage && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "fastmail", "email", "jmap"],
  "author": "Jeremy Gill",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "tsdav": "^2.1.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20.0.0",
    "c8": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "c8": {
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 80,
    "statements": 80,
    "reporter": ["text", "lcov", "html"],
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
  }
}
